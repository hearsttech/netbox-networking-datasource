Device Name,Site Name,Site Description,Facility,Physical Address,City,State,Site Tier,Device Type,Manufacturer,Role,Serial Number,Tenant,Tenant Group,Secondary Firewall,EC License,End of Life,VAR,Support Group,Support Level
{% set dict = {} -%}
{% for device in queryset -%}
{% if device.device_type.cf.eol -%}
{% set time = device.last_updated|string -%}
{% set now = time.split(' ')[0]|replace("-","0")|int -%}
{% set eol_int = device.device_type.cf.eol|replace("-","0")|int -%}
{% if eol_int > now -%}
{% set eol = device.device_type.cf.eol -%}
{% else -%}
{% set eol = "End of Life" -%}
{% endif -%}
{% else -%}
{% set eol = "Not Set" -%}
{% endif -%}
{% if device.site.name in dict.keys() -%}
{% set x = dict.update({device.site.name: dict[device.site.name] + 
[{
"name": device.site.name, 
"sn": device.serial, 
"description": device.site.description, 
"facility": device.site.facility, 
"physical_address": device.site.physical_address, 
"city": device.site.region, 
"state": device.site.region.parent, 
"site_tier": device.site.group, 
"device_name": device.name, 
"device_type": device.device_type.model, 
"manufacturer": device.device_type.manufacturer.name, 
"eol": eol, 
"role": device.role.name, 
"tenant": device.tenant.name, 
"tenant_group": device.tenant.group.name, 
"var": device.cf.var, 
"secondary_firewall": device.cf.secondary, 
"ec_license": device.cf.ec_license, 
"support_group": device.cf.support_group}]}) -%}
{% else -%}
{% set x = dict.update({device.site.name: 
[{
"name": device.site.name, 
"sn": device.serial, 
"description": device.site.description, 
"facility": device.site.facility, 
"physical_address": device.site.physical_address, 
"city": device.site.region, 
"state": device.site.region.parent, 
"site_tier": device.site.group, 
"device_name": device.name, 
"device_type": device.device_type.model, 
"manufacturer": device.device_type.manufacturer.name, 
"eol": eol, 
"role": device.role.name, 
"tenant": device.tenant.name, 
"tenant_group": device.tenant.group.name, 
"var": device.cf.var, 
"secondary_firewall": device.cf.secondary, 
"ec_license": device.cf.ec_license, 
"support_group": device.cf.support_group}]}) -%}
{% endif -%}
{% endfor -%}
{% set support_key = {
    "CDS": "License",
    "HTS-Curvature": "Full Support",
    "HTS": "Full Support",
    "HTV": "Labor and License",
    } -%}
{% set sorted = dict|dictsort -%}
{% for site, info in sorted -%}
{% for info in info -%}
{% set support_level = support_key.get(info.var, "Unknown") -%}
"{{ info.device_name }}","{{ site }}","{{ info.description }}","{{ info.facility }}","{{ info.physical_address }}","{{ info.city }}","{{ info.state }}","{{ info.site_tier }}","{{ info.device_type }}","{{ info.manufacturer }}","{{ info.role }}","{{ info.sn }}","{{ info.tenant }}","{{ info.tenant_group }}","{{ info.secondary_firewall }}","{{ info.ec_license }}","{{ info.eol }}","{{ info.var }}","{{ info.support_group }}","{{ support_level }}"
{% endfor -%}
{% endfor -%}
